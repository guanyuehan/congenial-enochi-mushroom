<!DOCTYPE html>
<html>
  <head>
    <title>Mainframe</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="flex flex-col bg-gradient-to-b from-purple-900 via-purple-400 to-indigo-600 items-center min-h-screen">
    <img class="absolute top-[300px] left-[50px] w-60 h-30" src="/assets/cloud.png" alt="cloud.png">
    <img class="absolute top-[250px] right-[50px] w-60 h-30" src="/assets/cloud.png" alt="cloud.png">
    <img class="absolute top-[-80px] left-[-50px] size-64 w-80" src="/assets/icon.png" alt="icon.png">
    <img class="absolute right-[10px] top-0 w-40 h-30" src="/assets/sun.png" alt="sun.png">
    
    <div class="flex flex-col items-center justify-center bg-yellow-500 p-6 rounded-[40px] w-[450px] h-[350px] mb-3 mt-3">
      <div class="bg-white px-8 py-2 rounded-full text-xl mb-6 justify">
        Chat messages here
      </div>
      
      <div class="flex-1 w-full overflow-y-auto">
        <% if (posts && posts.length > 0) { %>
          <% for (let post of posts) { %>
            <div class="w-full bg-gray-300 px-4 py-2 mb-2 text-base rounded-[5px]">
              <%= post.content %>
            </div>
          <% } %>
        <% } else { %>
          <div class="w-full bg-gray-300 px-4 py-2 mb-2 text-base rounded-[5px] text-gray-600">
            No messages yet. Be the first to post!
          </div>
        <% } %>
      </div>
    </div>
    
    <form method="POST" action="/post" class="flex flex-col items-center gap-3">
      <textarea name="content" class="w-[450px] p-2 rounded-[5px]" placeholder="Type your message..." required style="resize: vertical; min-height: 60px;"></textarea>
      <button type="submit" class="bg-blue-400 text-white rounded-[5px] px-4 py-3 text-xl">Post Message</button>
    </form>
  </body>
</html>
